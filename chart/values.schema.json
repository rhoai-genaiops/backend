{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Canopy Backend Helm Chart Values Schema",
  "description": "Schema for validating values.yaml configuration for the Canopy Backend Helm chart",
  "definitions": {
    "endpoint": {
      "type": "string",
      "description": "Base URL for the model or LLaMA Stack endpoint this feature connects to",
      "pattern": "^https?://[^\\s]+$",
      "examples": [
        "http://llama-32-predictor:80/v1",
        "http://llama-stack-service:8321/v1"
      ]
    }
  },
  "properties": {
    "MLFLOW_TRACKING_URI": {
      "type": "string",
      "description": "MLflow tracking server URI",
      "examples": [
        "https://mlflow.apps.example.com/mlflow"
      ]
    },
    "chart_path": {
      "type": "string",
      "description": "Path to the Helm chart in the repository"
    },
    "repo_url": {
      "type": "string",
      "description": "URL of the source repository"
    },
    "target_revision": {
      "type": "string",
      "description": "Git revision (branch, tag, or commit) used by the ApplicationSet"
    },
    "summarization": {
      "type": "object",
      "description": "Configuration for summarization functionality",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable summarization functionality",
          "default": false
        },
        "endpoint": { "$ref": "#/definitions/endpoint" },
        "model": {
          "type": "string",
          "description": "Model identifier to use for summarization",
          "minLength": 1,
          "examples": [
            "llama32",
            "llama3.2"
          ]
        },
        "temperature": {
          "type": "number",
          "description": "Temperature for the model"
        },
        "max_tokens": {
          "type": "number",
          "description": "Max tokens for the model"
        },
        "mlflow_prompt": {
          "type": "string",
          "description": "MLflow prompt registry name for this feature",
          "examples": ["summarization"]
        },
        "mlflow_prompt_version": {
          "type": "string",
          "description": "MLflow prompt version for this feature (alias or number)",
          "default": "latest",
          "examples": ["latest", "1", "2"]
        }
      },
      "required": ["enabled"],
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["endpoint", "model", "mlflow_prompt"]
      },
      "additionalProperties": false
    },
    "information-search": {
      "type": "object",
      "description": "Configuration for information search functionality",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable information search functionality",
          "default": false
        },
        "endpoint": { "$ref": "#/definitions/endpoint" },
        "model": {
          "type": "string",
          "description": "Model identifier to use for information search",
          "minLength": 1,
          "examples": [
            "llama32",
            "llama3.2"
          ]
        },
        "temperature": {
          "type": "number",
          "description": "Temperature for the model"
        },
        "max_tokens": {
          "type": "number",
          "description": "Max tokens for the model"
        },
        "mlflow_prompt": {
          "type": "string",
          "description": "MLflow prompt registry name for this feature",
          "examples": ["information-search"]
        },
        "mlflow_prompt_version": {
          "type": "string",
          "description": "MLflow prompt version for this feature (alias or number)",
          "default": "latest",
          "examples": ["latest", "1", "2"]
        },
        "vector_db_id": {
          "type": "string",
          "description": "Vector database identifier to use for information search",
          "minLength": 1,
          "examples": [
            "latest",
            "v1.0",
            "production"
          ]
        },
        "repo_url": {
          "type": "string",
          "description": "Repository URL for the Helm chart"
        }
      },
      "required": ["enabled"],
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["endpoint", "model", "mlflow_prompt"]
      },
      "additionalProperties": false
    },
    "shields": {
      "type": "object",
      "description": "Configuration for input/output moderation shields",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable shields functionality",
          "default": false
        },
        "endpoint": { "$ref": "#/definitions/endpoint" },
        "input_shields": {
          "type": "array",
          "description": "Shield names for input moderation",
          "items": {
            "type": "string"
          },
          "examples": [
            ["hap", "language_detection", "prompt_injection"]
          ]
        },
        "output_shields": {
          "type": "array",
          "description": "Shield names for output moderation",
          "items": {
            "type": "string"
          }
        },
        "check_interval": {
          "type": "number",
          "description": "Interval for shield checks"
        }
      },
      "additionalProperties": false
    },
    "student-assistant": {
      "type": "object",
      "description": "Configuration for student assistant functionality",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable student assistant functionality",
          "default": false
        },
        "endpoint": { "$ref": "#/definitions/endpoint" },
        "model": {
          "type": "string",
          "description": "Model identifier to use for student assistant",
          "minLength": 1,
          "examples": [
            "llama32",
            "llama3.2"
          ]
        },
        "temperature": {
          "type": "number",
          "description": "Temperature for the model"
        },
        "max_tokens": {
          "type": "number",
          "description": "Max tokens for the model"
        },
        "mlflow_prompt": {
          "type": "string",
          "description": "MLflow prompt registry name for this feature",
          "examples": ["student-assistant"]
        },
        "mlflow_prompt_version": {
          "type": "string",
          "description": "MLflow prompt version for this feature (alias or number)",
          "default": "latest",
          "examples": ["latest", "1", "2"]
        },
        "vector_db_id": {
          "type": "string",
          "description": "Vector database identifier to use for knowledge base search",
          "minLength": 1,
          "examples": [
            "latest",
            "v1.0",
            "production"
          ]
        },
        "mcp_calendar_url": {
          "type": "string",
          "description": "URL for the MCP calendar server"
        }
      },
      "required": ["enabled"],
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["endpoint", "model", "mlflow_prompt"]
      },
      "additionalProperties": false
    },
    "socratic-tutor": {
      "type": "object",
      "description": "Configuration for Socratic tutor functionality",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable Socratic tutor functionality",
          "default": false
        },
        "endpoint": { "$ref": "#/definitions/endpoint" },
        "model": {
          "type": "string",
          "description": "Model identifier to use for Socratic tutoring (fine-tuned model)",
          "minLength": 1,
          "examples": [
            "socratic-tutor-lora",
            "llama32-socratic"
          ]
        },
        "temperature": {
          "type": "number",
          "description": "Temperature for the model"
        },
        "max_tokens": {
          "type": "number",
          "description": "Max tokens for the model"
        },
        "mlflow_prompt": {
          "type": "string",
          "description": "MLflow prompt registry name for this feature",
          "examples": ["socratic-tutor"]
        },
        "mlflow_prompt_version": {
          "type": "string",
          "description": "MLflow prompt version for this feature (alias or number)",
          "default": "latest",
          "examples": ["latest", "1", "2"]
        }
      },
      "required": ["enabled"],
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["endpoint", "model", "mlflow_prompt"]
      },
      "additionalProperties": false
    },
    "feedback": {
      "type": "object",
      "description": "Configuration for user feedback collection on AI responses",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable feedback collection functionality",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "ab_testing": {
      "type": "object",
      "description": "Configuration for A/B testing of prompts",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable A/B testing",
          "default": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["MLFLOW_TRACKING_URI"],
  "additionalProperties": false
}
